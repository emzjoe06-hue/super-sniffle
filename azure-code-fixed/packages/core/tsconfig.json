{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "dist",
    "lib": [
      "DOM",
      "DOM.Iterable",
      "ES2023"
    ],
    "composite": true,
    "types": [
      "node",
      "vitest/globals"
    ],
    "baseUrl": ".",
    "paths": {
      "azure-code-core": [
        "./index.ts"
      ]
    },
    "skipLibCheck": true
  },
  "include": [
    "index.ts",
    "src/**/*.ts",
    "src/**/*.json"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx"
  ]
}